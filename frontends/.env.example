# ─── Backend API URLs ─────────────────────────────────────────────────────────
# Replace with your own backend deployment URL (e.g. Render, Railway, etc.)
# For local development use: http://localhost:4000
VITE_MAIN_BACKEND_URL="https://your-backend.onrender.com"

# These are auto-derived from the main URL — just update VITE_MAIN_BACKEND_URL above
VITE_MAIN_BACKEND_URL_USER="https://your-backend.onrender.com/api/v1/createAccount"
VITE_MAIN_BACKEND_URL_ADMIN="https://your-backend.onrender.com/api/v1/Admin"
VITE_MAIN_BACKEND_URL_ORG="https://your-backend.onrender.com/api/v1/Org"
VITE_MAIN_BACKEND_URL_SHOW="https://your-backend.onrender.com/api/v1/Show"
VITE_MAIN_BACKEND_URL_THEATRE="https://your-backend.onrender.com/api/v1/Theatre"
VITE_MAIN_BACKEND_URL_PAYMENT="https://your-backend.onrender.com/api/v1/Payment"

# ─── Razorpay (Payments) ──────────────────────────────────────────────────────
# Get this from: https://dashboard.razorpay.com -> Settings -> API Keys
# Use rzp_test_xxx for test mode, rzp_live_xxx for production
VITE_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
