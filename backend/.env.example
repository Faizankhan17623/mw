# --- Cloudinary (File Storage) ---
# Get these from: https://console.cloudinary.com -> Settings -> API Keys
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_FOLDER_NAME="movie_Project"
CLOUDINARY_URL="cloudinary://your_api_key:your_api_secret@your_cloud_name"

# --- MongoDB ---
# Get this from: https://cloud.mongodb.com -> Your Cluster -> Connect -> Drivers
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/"

# --- Server ---
DEFAULT_PORT_NUMBER="4000"
SECOND_NUMBER="4001"

# --- JWT Secrets ---
# Use a long random string:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_PRIVATE_KEY="your_jwt_secret_key"
JWT_ORGAINEZER_PRIVATE_KEY="your_organizer_jwt_secret_key"

# --- Email (Nodemailer via Gmail) ---
# Use a Gmail App Password (not your real password)
# Enable at: https://myaccount.google.com -> Security -> 2FA -> App Passwords
HOST_NAME="smtp.gmail.com"
NODEMAILER_PORT_NUMBER="587"
MAIL_USER="your_gmail@gmail.com"
USER_NAME="your_gmail@gmail.com"
PASSWORD_NAME="xxxx xxxx xxxx xxxx"

# --- Razorpay (Payments) ---
# Get these from: https://dashboard.razorpay.com -> Settings -> API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRETS="your_razorpay_key_secret"
RAZORPAY_HEADERS="your_razorpay_webhook_secret"

# --- Bcrypt ---
PASSWORD_CHANGING_HASH_ROUNDS="10"
